{
  "name": "@cloudeval/core",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm -C ../shared build && tsup",
    "lint": "pnpm -C ../shared build && tsc --noEmit -p tsconfig.json",
    "test": "pnpm -C ../shared build && tsx --test src/auth.test.ts src/streamClient.test.ts src/reportsClient.test.ts src/billingClient.test.ts src/projectClient.test.ts"
  },
  "dependencies": {
    "@cloudeval/shared": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.3"
  }
}
